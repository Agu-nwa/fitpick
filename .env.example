# FitPick production beta environment
# Copy to .env.local on the server and fill real values there only.

# App URL
NODE_ENV=production
APP_URL=
NEXT_PUBLIC_APP_URL=

# MongoDB
MONGODB_URI=

# Auth/session
JWT_SECRET=
SESSION_COOKIE_NAME=fitpick_session
# Plain HTTP EC2 IP testing needs false. Switch to true when serving over HTTPS.
SESSION_COOKIE_SECURE=false

# OpenAI
OPENAI_API_KEY=
OPENAI_WARDROBE_MODEL=gpt-4.1-mini
OPENAI_OCR_MODEL=gpt-4.1-mini
OPENAI_STYLIST_MODEL=gpt-4.1-mini
OPENAI_RECOMMENDATION_MODEL=gpt-4.1-mini
OPENAI_IMAGE_GENERATION_MODEL=gpt-image-1
OPENAI_IMAGE_PROMPT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# S3/CloudFront
STORAGE_PROVIDER=s3
S3_BUCKET_NAME=
S3_BUCKET=
S3_REGION=eu-north-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
CLOUDFRONT_PUBLIC_URL=
S3_PUBLIC_BASE_URL=

# Background jobs
ENABLE_BACKGROUND_JOBS=true
WORKER_POLL_MS=5000

# remove.bg studio image processing
BACKGROUND_REMOVAL_PROVIDER=removebg
BACKGROUND_REMOVAL_API_KEY=
FITPICK_STUDIO_BACKGROUND_PRESET=ivory

# Billing and payments
PAYMENT_PROVIDER=placeholder
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=
FITPICK_PLUS_PAYSTACK_PLAN_CODE=
PAYSTACK_CALLBACK_URL=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
FITPICK_PLUS_STRIPE_PRICE_ID=
FITPICK_PLUS_PRICE_ID=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=

# Rate limiting/cache
AI_CACHE_PROVIDER=memory
REDIS_URL=
RATE_LIMIT_PROVIDER=memory
RATE_LIMIT_REDIS_URL=
